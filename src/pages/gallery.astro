---

<Layout title="Gallery" subtitle="Fragments of my memory, lovely daily life." description="gallery">

  <div class="grid">
    {photos.map((photo, i) => (
      <button class="card" data-index={i} aria-label={photo.title}>
        <img src={photo.src} alt={photo.title} loading="lazy" />
        <div class="overlay"></div>
      </button>
    ))}
  </div>

  <!-- Modal -->
  <div id="modal" class="modal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="modal-backdrop"></div>
    <div class="modal-content">
      <img id="modal-img" src="" alt="" />
      <div class="modal-info">
        <p id="modal-title" class="modal-title"></p>
        <p id="modal-description" class="modal-description"></p>
        <div id="modal-meta" class="modal-meta"></div>
      </div>
    </div>
  </div>

</Layout>

<script define:vars={{ photos }}>
  const modal = document.getElementById('modal');
  const modalImg = document.getElementById('modal-img');
  const modalTitle = document.getElementById('modal-title');
  const modalMeta = document.getElementById('modal-meta');
  const backdrop = modal.querySelector('.modal-backdrop');

  function openModal(index) {
    const photo = photos[index];

    modalImg.style.opacity = '0';
    modalImg.onload = () => { modalImg.style.opacity = '1'; };
    modalImg.src = photo.src;
    modalImg.alt = photo.title;
    if (modalImg.complete) modalImg.style.opacity = '1';

    modalTitle.textContent = photo.title;

    const metaParts = [];
    if (photo.camera) metaParts.push(photo.camera);
    if (photo.date) metaParts.push(photo.date);
    modalMeta.textContent = metaParts.join(' / ');

    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.setAttribute('aria-hidden', 'true');
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.card').forEach((card) => {
    card.addEventListener('click', () => openModal(Number(card.dataset.index)));
  });

  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });
</script>

<style>
  /* Responsive grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
    margin-top: 2rem;
  }

  @media (max-width: 480px) {
    .grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 0.5rem;
    }
  }

  /* Card */
  .card {
    position: relative;
    cursor: pointer;
    border: none;
    padding: 0;
    background: none;
    border-radius: 0;
    overflow: hidden;
    display: block;
    width: 100%;
  }

  .card img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    border-radius: 0;
    transition: opacity 0.2s ease;
  }

  .card:hover img,
  .card:focus img {
    opacity: 0.85;
  }

  .overlay {
    position: absolute;
    inset: 0;
  }

  /* Modal */
  .modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }

  .modal.is-open {
    display: flex;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.72);
  }

  .modal-content {
    position: relative;
    z-index: 1;
    background: var(--background);
    border-radius: 0;
    max-width: min(680px, calc(100vw - 2rem));
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.35);
    display: flex;
    flex-direction: column;
  }

  .modal-content img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    margin: 0;
    max-height: 80vh;
    object-fit: contain;
    transition: opacity 0.15s ease;
  }

  .modal-info {
    padding: 1.25em 1.5em 1.5em;
  }

  .modal-title {
    font-size: 1em;
    font-weight: 700;
    margin: 0 0 0.4em;
    color: var(--foreground);
  }

  .modal-meta {
    font-size: 0.75em;
    color: var(--accent);
  }

</style>
